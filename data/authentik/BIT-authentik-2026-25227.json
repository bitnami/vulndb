{
  "schema_version": "1.6.2",
  "id": "BIT-authentik-2026-25227",
  "summary": "authentik affected by Remote Code Execution via Context Key Injection in PropertyMapping Test Endpoint",
  "details": "authentik is an open-source identity provider. From 2021.3.1 to before 2025.8.6, 2025.10.4, and 2025.12.4, when using delegated permissions, a User that has the permission Can view * Property Mapping or Can view Expression Policy is able to execute arbitrary code within the authentik server container through the test endpoint, which is intended to preview how a property mapping/policy works. authentik 2025.8.6, 2025.10.4, and 2025.12.4 fix this issue.",
  "aliases": [
    "CVE-2026-25227"
  ],
